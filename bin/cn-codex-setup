#!/usr/bin/env bash
# cn-codex-setup — 国产大模型 Codex CLI 交互式配置工具

set -euo pipefail

CN_CODEX_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CN_CODEX_HOME="${CN_CODEX_HOME:-$HOME/.cn-codex}"
PROVIDERS_DIR="${CN_CODEX_DIR}/providers"

# === 颜色 ===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

info()  { echo -e "${BLUE}ℹ${NC} $*"; }
ok()    { echo -e "${GREEN}✔${NC} $*"; }
warn()  { echo -e "${YELLOW}⚠${NC} $*"; }
error() { echo -e "${RED}✖${NC} $*" >&2; }

# === Provider 定义 ===

declare -A PROVIDER_NAMES=(
    [deepseek]="DeepSeek"
    [qwen]="通义千问 (Qwen)"
    [zhipu]="智谱 GLM"
    [kimi]="Kimi (月之暗面)"
    [doubao]="豆包 (字节跳动)"
    [siliconflow]="SiliconFlow (多模型聚合)"
    [custom]="自定义 OpenAI 兼容 API"
)

declare -A PROVIDER_BASE_URLS=(
    [deepseek]="https://api.deepseek.com/v1"
    [qwen]="https://dashscope.aliyuncs.com/compatible-mode/v1"
    [zhipu]="https://open.bigmodel.cn/api/paas/v4"
    [kimi]="https://api.moonshot.cn/v1"
    [doubao]="https://ark.cn-beijing.volces.com/api/v3"
    [siliconflow]="https://api.siliconflow.cn/v1"
)

declare -A PROVIDER_ENV_KEYS=(
    [deepseek]="DEEPSEEK_API_KEY"
    [qwen]="DASHSCOPE_API_KEY"
    [zhipu]="ZHIPU_API_KEY"
    [kimi]="MOONSHOT_API_KEY"
    [doubao]="VOLC_API_KEY"
    [siliconflow]="SILICONFLOW_API_KEY"
)

declare -A PROVIDER_KEY_URLS=(
    [deepseek]="https://platform.deepseek.com/api_keys"
    [qwen]="https://dashscope.console.aliyun.com/apiKey"
    [zhipu]="https://open.bigmodel.cn/usercenter/apikeys"
    [kimi]="https://platform.moonshot.cn/console/api-keys"
    [doubao]="https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey"
    [siliconflow]="https://cloud.siliconflow.cn/account/ak"
)

declare -A PROVIDER_DEFAULT_MODELS=(
    [deepseek]="deepseek-chat"
    [qwen]="qwen-plus"
    [zhipu]="glm-4-plus"
    [kimi]="moonshot-v1-8k"
    [doubao]="doubao-pro-32k"
    [siliconflow]="deepseek-ai/DeepSeek-V3"
)

declare -A PROVIDER_MODELS=(
    [deepseek]="deepseek-chat deepseek-reasoner deepseek-coder"
    [qwen]="qwen-plus qwen-turbo qwen-max qwen-long"
    [zhipu]="glm-4-plus glm-4-flash glm-4 glm-4-long"
    [kimi]="moonshot-v1-8k moonshot-v1-32k moonshot-v1-128k"
    [doubao]="doubao-pro-32k doubao-pro-128k doubao-lite-32k"
    [siliconflow]="deepseek-ai/DeepSeek-V3 deepseek-ai/DeepSeek-R1 Qwen/Qwen3-235B-A22B"
)

# === 交互式选择 ===

select_provider() {
    echo ""
    echo -e "${BOLD}${CYAN}🇨🇳 cn-codex 国产大模型配置向导${NC}"
    echo -e "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "请选择模型提供商："
    echo ""

    local i=1
    local ids=()
    for id in deepseek qwen zhipu kimi doubao siliconflow custom; do
        echo -e "  ${BOLD}${i})${NC} ${PROVIDER_NAMES[$id]}"
        ids+=("$id")
        i=$((i + 1))
    done

    echo ""
    read -rp "请输入编号 [1-7] (默认: 1): " choice
    choice="${choice:-1}"

    if [[ "$choice" -lt 1 || "$choice" -gt 7 ]] 2>/dev/null; then
        error "无效选择"
        return 1
    fi

    echo "${ids[$((choice - 1))]}"
}

select_model() {
    local provider="$1"
    local models="${PROVIDER_MODELS[$provider]:-}"
    local default="${PROVIDER_DEFAULT_MODELS[$provider]:-}"

    if [[ -z "$models" ]]; then
        echo "$default"
        return
    fi

    echo ""
    echo "可用模型："
    local i=1
    local model_list=()
    for model in $models; do
        local marker=""
        if [[ "$model" == "$default" ]]; then
            marker=" ${GREEN}(推荐)${NC}"
        fi
        echo -e "  ${BOLD}${i})${NC} ${model}${marker}"
        model_list+=("$model")
        i=$((i + 1))
    done

    echo ""
    read -rp "请选择模型 (默认: ${default}): " choice
    if [[ -z "$choice" ]]; then
        echo "$default"
        return
    fi

    if [[ "$choice" -ge 1 && "$choice" -le ${#model_list[@]} ]] 2>/dev/null; then
        echo "${model_list[$((choice - 1))]}"
    else
        echo "$default"
    fi
}

input_api_key() {
    local provider="$1"
    local env_key="${PROVIDER_ENV_KEYS[$provider]:-API_KEY}"
    local key_url="${PROVIDER_KEY_URLS[$provider]:-}"

    # 检查环境变量是否已设置
    local existing_key="${!env_key:-}"
    if [[ -n "$existing_key" ]]; then
        echo ""
        read -rp "检测到 ${env_key} 已设置，是否使用？[Y/n]: " use_existing
        if [[ "${use_existing:-Y}" =~ ^[Yy] ]]; then
            echo "$existing_key"
            return
        fi
    fi

    echo ""
    if [[ -n "$key_url" ]]; then
        echo -e "获取 API Key: ${CYAN}${key_url}${NC}"
    fi
    read -rsp "请输入 API Key: " api_key
    echo ""

    if [[ -z "$api_key" ]]; then
        error "API Key 不能为空"
        return 1
    fi

    echo "$api_key"
}

input_custom_provider() {
    echo ""
    read -rp "请输入 Provider 名称: " name
    read -rp "请输入 API Base URL: " base_url
    read -rp "请输入 API Key 环境变量名 (如: MY_API_KEY): " env_key
    read -rp "请输入默认模型名称: " model

    echo "${name}|${base_url}|${env_key}|${model}"
}

# === 配置生成 ===

save_config() {
    local provider="$1"
    local model="$2"
    local api_key="$3"
    local base_url="$4"
    local env_key="$5"

    mkdir -p "$CN_CODEX_HOME"

    # 保存当前 provider 配置（供桥接代理使用）
    cat > "${CN_CODEX_HOME}/current-provider.env" << EOF
# cn-codex 当前提供商配置
# 由 cn-codex-setup 自动生成，请勿手动修改

PROVIDER_ID="${provider}"
PROVIDER_BASE_URL="${base_url}"
PROVIDER_ENV_KEY="${env_key}"
PROVIDER_MODEL="${model}"
EOF

    # 保存 API Key 到环境变量文件
    cat > "${CN_CODEX_HOME}/api-keys.env" << EOF
# cn-codex API Keys
# 由 cn-codex-setup 自动生成
# 警告: 此文件包含敏感信息，请勿提交到版本控制

export ${env_key}="${api_key}"
EOF
    chmod 600 "${CN_CODEX_HOME}/api-keys.env"

    # 生成 shell 配置片段（用户可以 source 到 .bashrc/.zshrc）
    cat > "${CN_CODEX_HOME}/env.sh" << EOF
# cn-codex 环境变量
# 添加到 ~/.bashrc 或 ~/.zshrc:
# source ~/.cn-codex/env.sh

export ${env_key}="${api_key}"
export CN_CODEX_BRIDGE_PORT="${CN_CODEX_BRIDGE_PORT:-15721}"
EOF

    # 生成 Codex config.toml
    local codex_config="${HOME}/.codex/config.toml"
    mkdir -p "$(dirname "$codex_config")"

    # 备份已有配置
    if [[ -f "$codex_config" ]]; then
        cp "$codex_config" "${codex_config}.bak.$(date +%Y%m%d%H%M%S)"
    fi

    cat > "$codex_config" << EOF
# cn-codex 自动生成配置
# 提供商: ${provider} (${PROVIDER_NAMES[$provider]:-$provider})
# 模型: ${model}
# 生成时间: $(date '+%Y-%m-%d %H:%M:%S')

model = "${model}"
model_provider = "cn-bridge"

[model_providers.cn-bridge]
name = "CN Bridge (${PROVIDER_NAMES[$provider]:-$provider})"
base_url = "http://127.0.0.1:${CN_CODEX_BRIDGE_PORT:-15721}/v1"
wire_api = "responses"
stream_idle_timeout_ms = 600000
request_max_retries = 4
stream_max_retries = 10
EOF

    ok "配置已保存"
}

# === 主流程 ===

main() {
    # 检查依赖
    if ! command -v codex &>/dev/null; then
        warn "Codex CLI 未安装"
        read -rp "是否自动安装？[Y/n]: " answer
        if [[ "${answer:-Y}" =~ ^[Yy] ]]; then
            if command -v npm &>/dev/null; then
                npm install -g @openai/codex
                ok "Codex CLI 安装完成"
            else
                error "npm 未安装，请先安装 Node.js"
                exit 1
            fi
        else
            exit 0
        fi
    fi

    # 选择 Provider
    local provider
    provider=$(select_provider) || exit 1

    local base_url env_key model api_key

    if [[ "$provider" == "custom" ]]; then
        local custom
        custom=$(input_custom_provider) || exit 1
        IFS='|' read -r _ base_url env_key model <<< "$custom"
        api_key=$(input_api_key "custom") || exit 1
        PROVIDER_NAMES[custom]="自定义 (${base_url})"
    else
        base_url="${PROVIDER_BASE_URLS[$provider]}"
        env_key="${PROVIDER_ENV_KEYS[$provider]}"
        model=$(select_model "$provider") || exit 1
        api_key=$(input_api_key "$provider") || exit 1
    fi

    # 确认配置
    echo ""
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}配置确认${NC}"
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  提供商:  ${CYAN}${PROVIDER_NAMES[$provider]:-$provider}${NC}"
    echo -e "  Base URL: ${CYAN}${base_url}${NC}"
    echo -e "  模型:    ${CYAN}${model}${NC}"
    echo -e "  API Key:  ${DIM}${env_key}=sk-***...***${NC}"
    echo ""

    read -rp "确认保存配置？[Y/n]: " confirm
    if [[ "${confirm:-Y}" !~ ^[Yy] ]]; then
        warn "已取消"
        exit 0
    fi

    # 保存配置
    save_config "$provider" "$model" "$api_key" "$base_url" "$env_key"

    echo ""
    echo -e "${BOLD}${GREEN}🇨🇳 配置完成！${NC}"
    echo ""
    echo -e "  ${DIM}1.${NC} 将环境变量添加到 shell 配置："
    echo -e "     ${CYAN}echo 'source ~/.cn-codex/env.sh' >> ~/.bashrc${NC}"
    echo -e "     ${CYAN}source ~/.cn-codex/env.sh${NC}"
    echo ""
    echo -e "  ${DIM}2.${NC} 启动使用："
    echo -e "     ${CYAN}cn-codex \"你的任务\"${NC}"
    echo ""
    echo -e "  ${DIM}3.${NC} 管理桥接代理："
    echo -e "     ${CYAN}cn-codex bridge status${NC}   查看状态"
    echo -e "     ${CYAN}cn-codex bridge restart${NC}  重启代理"
    echo ""
}

main "$@"
