#!/usr/bin/env bash
# cn-codex — 国产大模型 Codex CLI 增强版
# 在官方 Codex CLI 基础上，自动配置国产大模型并启动本地协议桥接代理

set -euo pipefail

# === 常量 ===
CN_CODEX_VERSION="0.1.0"
CN_CODEX_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CN_CODEX_HOME="${CN_CODEX_HOME:-$HOME/.cn-codex}"
BRIDGE_BIN="${CN_CODEX_HOME}/bin/cn-codex-bridge"
BRIDGE_PORT="${CN_CODEX_BRIDGE_PORT:-15721}"
BRIDGE_PID_FILE="${CN_CODEX_HOME}/bridge.pid"
CODEX_CONFIG="${HOME}/.codex/config.toml"
PROVIDERS_DIR="${CN_CODEX_DIR}/providers"

# === 颜色 ===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${BLUE}[cn-codex]${NC} $*"; }
ok()    { echo -e "${GREEN}[cn-codex]${NC} $*"; }
warn()  { echo -e "${YELLOW}[cn-codex]${NC} $*"; }
error() { echo -e "${RED}[cn-codex]${NC} $*" >&2; }

# === 工具函数 ===

# 检查 codex CLI 是否已安装
check_codex() {
    if command -v codex &>/dev/null; then
        return 0
    fi
    return 1
}

# 安装 codex CLI
install_codex() {
    info "正在安装 Codex CLI..."
    if command -v npm &>/dev/null; then
        npm install -g @openai/codex 2>/dev/null && {
            ok "Codex CLI 安装成功"
            return 0
        }
    fi
    if command -v brew &>/dev/null; then
        brew install codex 2>/dev/null && {
            ok "Codex CLI 安装成功"
            return 0
        }
    fi
    error "无法自动安装 Codex CLI，请手动安装: npm install -g @openai/codex"
    return 1
}

# 检查桥接代理是否在运行
is_bridge_running() {
    if [[ -f "$BRIDGE_PID_FILE" ]]; then
        local pid
        pid=$(cat "$BRIDGE_PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        rm -f "$BRIDGE_PID_FILE"
    fi
    return 1
}

# 启动桥接代理
start_bridge() {
    if is_bridge_running; then
        return 0
    fi

    if [[ ! -x "$BRIDGE_BIN" ]]; then
        error "桥接代理未安装: $BRIDGE_BIN"
        error "请运行: cn-codex-setup"
        return 1
    fi

    info "正在启动协议桥接代理 (端口: ${BRIDGE_PORT})..."
    mkdir -p "$CN_CODEX_HOME"

    # 读取当前 provider 的配置
    local provider_config="${CN_CODEX_HOME}/current-provider.env"
    if [[ ! -f "$provider_config" ]]; then
        error "未配置国产模型提供商，请运行: cn-codex-setup"
        return 1
    fi

    source "$provider_config"

    # 启动桥接代理
    nohup "$BRIDGE_BIN" \
        --port "$BRIDGE_PORT" \
        --upstream-url "${PROVIDER_BASE_URL}" \
        --api-key-env "${PROVIDER_ENV_KEY}" \
        > "${CN_CODEX_HOME}/bridge.log" 2>&1 &

    local pid=$!
    echo "$pid" > "$BRIDGE_PID_FILE"

    # 等待代理启动
    local retries=0
    while ! curl -s "http://127.0.0.1:${BRIDGE_PORT}/health" &>/dev/null; do
        sleep 0.5
        retries=$((retries + 1))
        if [[ $retries -ge 10 ]]; then
            error "桥接代理启动超时，请检查日志: ${CN_CODEX_HOME}/bridge.log"
            return 1
        fi
    done

    ok "桥接代理已启动 (PID: ${pid}, 端口: ${BRIDGE_PORT})"
}

# 停止桥接代理
stop_bridge() {
    if is_bridge_running; then
        local pid
        pid=$(cat "$BRIDGE_PID_FILE")
        kill "$pid" 2>/dev/null || true
        rm -f "$BRIDGE_PID_FILE"
        ok "桥接代理已停止"
    fi
}

# 确保 config.toml 配置正确
ensure_config() {
    mkdir -p "$(dirname "$CODEX_CONFIG")"

    # 检查是否已配置指向本地桥接
    if [[ -f "$CODEX_CONFIG" ]]; then
        if grep -q "base_url.*127.0.0.1:${BRIDGE_PORT}" "$CODEX_CONFIG" 2>/dev/null; then
            return 0
        fi
    fi

    # 自动生成配置
    local provider="${PROVIDER_ID:-deepseek}"
    local model="${PROVIDER_MODEL:-deepseek-chat}"

    cat > "$CODEX_CONFIG" << EOF
# cn-codex 自动生成配置
# 提供商: ${provider}
# 模型: ${model}
# 桥接代理: http://127.0.0.1:${BRIDGE_PORT}/v1

model = "${model}"
model_provider = "cn-bridge"

[model_providers.cn-bridge]
name = "CN Bridge (via cn-codex)"
base_url = "http://127.0.0.1:${BRIDGE_PORT}/v1"
wire_api = "responses"
stream_idle_timeout_ms = 600000
EOF

    ok "已自动配置 ~/.codex/config.toml"
}

# === 子命令 ===

cmd_setup() {
    exec "${CN_CODEX_DIR}/bin/cn-codex-setup" "$@"
}

cmd_bridge() {
    local action="${1:-}"
    case "$action" in
        start)   start_bridge ;;
        stop)    stop_bridge ;;
        restart) stop_bridge; start_bridge ;;
        status)
            if is_bridge_running; then
                ok "桥接代理运行中 (PID: $(cat "$BRIDGE_PID_FILE"), 端口: ${BRIDGE_PORT})"
            else
                warn "桥接代理未运行"
            fi
            ;;
        log)
            local log_file="${CN_CODEX_HOME}/bridge.log"
            if [[ -f "$log_file" ]]; then
                tail -f "$log_file"
            else
                warn "日志文件不存在"
            fi
            ;;
        *)
            echo "用法: cn-codex bridge {start|stop|restart|status|log}"
            return 1
            ;;
    esac
}

cmd_version() {
    echo "cn-codex v${CN_CODEX_VERSION}"
    if check_codex; then
        echo "codex   $(codex --version 2>/dev/null || echo 'unknown')"
    fi
}

# === 主入口 ===

main() {
    # 拦截 cn-codex 自有子命令
    case "${1:-}" in
        setup)  shift; cmd_setup "$@"; return ;;
        bridge) shift; cmd_bridge "$@"; return ;;
        --version|-v) cmd_version; return ;;
        --help|-h)
            echo "cn-codex v${CN_CODEX_VERSION} — 国产大模型 Codex CLI 增强版"
            echo ""
            echo "用法: cn-codex [选项] [提示词]"
            echo ""
            echo "子命令:"
            echo "  setup             配置国产大模型提供商"
            echo "  bridge start      启动协议桥接代理"
            echo "  bridge stop       停止协议桥接代理"
            echo "  bridge status     查看代理状态"
            echo "  bridge log        查看代理日志"
            echo ""
            echo "选项:"
            echo "  --version, -v     显示版本"
            echo "  --help, -h        显示帮助"
            echo ""
            echo "其他选项将透传给 codex CLI"
            return 0
            ;;
    esac

    # 检查 codex 是否已安装
    if ! check_codex; then
        warn "Codex CLI 未安装"
        read -rp "是否自动安装？[Y/n] " answer
        if [[ "${answer:-Y}" =~ ^[Yy] ]]; then
            install_codex || return 1
        else
            return 1
        fi
    fi

    # 启动桥接代理
    start_bridge || return 1

    # 确保配置正确
    ensure_config

    # 透传给 codex CLI
    info "启动 Codex CLI..."
    exec codex "$@"
}

main "$@"
